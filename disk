                f"rm -rf ~/Library/Caches/{entry}")

    # ── Browser caches ──
    # Chrome
    chrome_base = os.path.join(home, "Library", "Application Support", "Google", "Chrome")
    chrome_cache = (
        dir_size_if_exists(os.path.join(home, "Library", "Caches", "Google", "Chrome"))
        + dir_size_if_exists(os.path.join(chrome_base, "Default", "Service Worker"))
        + dir_size_if_exists(os.path.join(chrome_base, "Default", "Code Cache"))
        + dir_size_if_exists(os.path.join(chrome_base, "Default", "GPUCache"))
        + dir_size_if_exists(os.path.join(chrome_base, "ShaderCache"))
    )
    add("Chrome cache",
        "Browser cache, service workers, shader/GPU cache",
        chrome_cache,
        "rm -rf ~/Library/Caches/Google/Chrome/ "
        "~/Library/Application\\ Support/Google/Chrome/Default/{Service\\ Worker,Code\\ Cache,GPUCache} "
        "~/Library/Application\\ Support/Google/Chrome/ShaderCache")

    # Firefox
    ff_cache = (
        dir_size_if_exists(os.path.join(home, "Library", "Caches", "Firefox"))
        + dir_size_if_exists(os.path.join(home, ".cache", "mozilla"))
    )
    add("Firefox cache",
        "Browser cache files",
        ff_cache,
        "rm -rf ~/Library/Caches/Firefox/ ~/.cache/mozilla/")

    # Brave
    brave_base = os.path.join(home, "Library", "Application Support", "BraveSoftware", "Brave-Browser")
    brave_cache = (
        dir_size_if_exists(os.path.join(home, "Library", "Caches", "BraveSoftware"))
        + dir_size_if_exists(os.path.join(brave_base, "Default", "Service Worker"))
        + dir_size_if_exists(os.path.join(brave_base, "Default", "Code Cache"))
        + dir_size_if_exists(os.path.join(brave_base, "Default", "GPUCache"))
    )
    add("Brave cache",
        "Browser cache, service workers, GPU cache",
        brave_cache,
        "rm -rf ~/Library/Caches/BraveSoftware/ "
        "~/Library/Application\\ Support/BraveSoftware/Brave-Browser/Default/{Service\\ Worker,Code\\ Cache,GPUCache}")

    # Safari (just the cache dir, not cookies/data)
    safari_cache = dir_size_if_exists(os.path.join(home, "Library", "Caches", "com.apple.Safari"))
    add("Safari cache",
        "Browser cache and webpage previews",
        safari_cache,
        "rm -rf ~/Library/Caches/com.apple.Safari/")

    # Edge
    edge_cache = dir_size_if_exists(os.path.join(home, "Library", "Caches", "Microsoft Edge"))
    add("Edge cache",
        "Browser cache files",
        edge_cache,
        "rm -rf ~/Library/Caches/Microsoft\\ Edge/")

    # ── Electron app caches ──
    electron_apps = {
        "Discord":  "discord",
        "Slack":    "Slack",
        "VS Code":  "Code",
        "Teams":    "Microsoft Teams",
    }
    for label, dirname in electron_apps.items():
        app_base = os.path.join(home, "Library", "Application Support", dirname)
        if not os.path.isdir(app_base):
            continue
        ecache = 0
        for sub in ("Cache", "CachedData", "Code Cache", "GPUCache", "Service Worker"):
            ecache += dir_size_if_exists(os.path.join(app_base, sub))
        add(f"{label} cache",
            "Electron app cache — will be regenerated",
            ecache,
            f"rm -rf ~/Library/Application\\ Support/{dirname}/{{Cache,CachedData,Code\\ Cache,GPUCache,Service\\ Worker}}")

    # ── Zoom ──
    zoom_cache = dir_size_if_exists(os.path.join(home, "Library", "Caches", "us.zoom.xos"))
    zoom_logs = dir_size_if_exists(os.path.join(home, "Library", "Logs", "zoom.us"))
    add("Zoom cache & logs",
        "Zoom app cache and log files",
        zoom_cache + zoom_logs,
        "rm -rf ~/Library/Caches/us.zoom.xos/ ~/Library/Logs/zoom.us/")

    zoom_recordings = dir_size_if_exists(os.path.join(home, "Documents", "Zoom"))
    add("Zoom recordings",
        "Local Zoom meeting recordings — review before deleting",
        zoom_recordings,
        "ls -lhS ~/Documents/Zoom/  (review, then delete selectively)",
        CAUTION)

    # iOS backups — smart duplicate detection
    backup_dir = os.path.join(home, "Library", "Application Support",
                              "MobileSync", "Backup")
    if os.path.isdir(backup_dir):
        import plistlib
        from collections import defaultdict
        devices = defaultdict(list)  # device_name -> [(date, path, size)]
        try:
            for entry in os.listdir(backup_dir):
                entry_path = os.path.join(backup_dir, entry)
                plist_path = os.path.join(entry_path, "Info.plist")
                if not os.path.isfile(plist_path):
                    continue
                try:
                    with open(plist_path, "rb") as f:
                        info = plistlib.load(f)
                    device = info.get("Device Name", "Unknown device")
                    date = info.get("Last Backup Date")
                    size = du_size(entry_path)
                    devices[device].append((date, entry_path, size))
                except Exception:
                    continue
        except OSError:
            pass

        for device, backups in devices.items():
            total_size = sum(s for _, _, s in backups)
            if len(backups) > 1:
                backups.sort(key=lambda x: x[0] or "")
                oldest_date = backups[0][0]
                oldest_str = oldest_date.strftime("%Y-%m-%d") if oldest_date else "unknown date"
                old_size = sum(s for _, _, s in backups[:-1])
                add(f"iOS backups ({device})",
                    f"{len(backups)} backups found — oldest from {oldest_str}. "
                    f"Consider keeping only the latest",
                    old_size,
                    f"rm -rf {backups[0][1]}",
                    CAUTION)
            elif total_size > 0:
                date_str = backups[0][0].strftime("%Y-%m-%d") if backups[0][0] else "unknown date"
                add(f"iOS backup ({device})",
                    f"Single backup from {date_str} — no duplicates",
                    total_size,
                    "(no action needed — keeping your only backup)",
                    CAUTION)

    # Android emulator snapshots
    add("Android emulator data",
        "AVD images and snapshots",
        dir_size_if_exists(os.path.join(home, ".android", "avd")),
        "Manage in Android Studio > Device Manager",
        REVIEW)

    # ── ~/.cache top offenders (cross-platform tools) ──
    dot_cache = os.path.join(home, ".cache")
    # Exclude dirs already reported separately
    already_dot_cache = {"pip", "mozilla"}
    if os.path.isdir(dot_cache):
        try:
            for entry in os.listdir(dot_cache):
                if entry in already_dot_cache:
                    continue
                path = os.path.join(dot_cache, entry)
                if os.path.isdir(path) and not os.path.islink(path):
                    size = du_size(path)
                    if size >= 100_000_000:  # 100 MB+
                        add(f"Cache: ~/.cache/{entry}",
                            "CLI tool cache — will be re-downloaded as needed",
                            size,
                            f"rm -rf ~/.cache/{entry}")
        except OSError:
            pass

    # Go module cache
    go_cache = dir_size_if_exists(os.path.join(home, "go", "pkg", "mod", "cache"))
    add("Go module cache",
        "Cached Go module downloads",
        go_cache,
        "go clean -modcache")

    # Docker (check if docker is available)
    try:
        r = subprocess.run(["docker", "system", "df", "--format", "{{.Size}}"],
                           capture_output=True, text=True, timeout=5)
        if r.returncode == 0 and r.stdout.strip():
            # Just report that docker can be pruned, use the reclaimable info
            r2 = subprocess.run(
                ["docker", "system", "df", "--format", "{{.Reclaimable}}"],
                capture_output=True, text=True, timeout=5)
            if r2.returncode == 0:
                reclaimable_lines = r2.stdout.strip().splitlines()
                # Parse first reclaimable value as a rough indicator
                total_reclaim = 0
                for line in reclaimable_lines:
                    line = line.strip().split()[0]  # e.g. "2.5GB"
                    try:
                        if "GB" in line:
                            total_reclaim += float(line.replace("GB", "")) * 1_000_000_000
                        elif "MB" in line:
                            total_reclaim += float(line.replace("MB", "")) * 1_000_000
                    except ValueError:
                        pass
                if total_reclaim > 0:
                    add("Docker reclaimable",
                        "Unused images, containers, build cache",
                        int(total_reclaim),
                        "docker system prune -a",
                        REVIEW)
    except (FileNotFoundError, Exception):
        pass

    # ── Homebrew checks ──
    try:
        # Check if brew exists
        subprocess.run(["brew", "--prefix"], capture_output=True, timeout=5)
        brew_prefix = "/opt/homebrew"
        if not os.path.isdir(brew_prefix):
            brew_prefix = "/usr/local"

        # 1. Orphaned Python lib directories
        lib_dir = os.path.join(brew_prefix, "lib")
        if os.path.isdir(lib_dir):
            try:
                for entry in os.listdir(lib_dir):
                    if not entry.startswith("python3."):
                        continue
                    # Extract version like "3.10" from "python3.10"
                    pyver = entry.replace("python", "")
                    # Check if the corresponding formula is installed
                    r = subprocess.run(
                        ["brew", "list", f"python@{pyver}"],
                        capture_output=True, text=True, timeout=5,
                    )
                    if r.returncode != 0:
                        # Formula not installed — orphaned lib dir
                        path = os.path.join(lib_dir, entry)
                        size = du_size(path)
                        add(f"Orphaned {entry} libs",
                            f"python@{pyver} is not installed — leftover files",
                            size,
                            f"rm -rf {path}")
            except OSError:
                pass

        # 2. brew cleanup (stale downloads, old versions)
        try:
            r = subprocess.run(
                ["brew", "cleanup", "--dry-run"],
                capture_output=True, text=True, timeout=15,
            )
            if r.returncode == 0 and r.stdout.strip():
                # Count files and estimate size
                cleanup_files = [
                    l.strip() for l in r.stdout.splitlines()
                    if l.strip() and os.path.exists(l.strip())
                ]
                cleanup_size = sum(
                    os.path.getsize(f) if os.path.isfile(f) else du_size(f)
                    for f in cleanup_files
                )
                add("Homebrew stale files",
                    f"{len(cleanup_files)} old downloads/versions to clean up",
                    cleanup_size,
                    "brew cleanup")
        except Exception:
            pass

        # 3. Multiple versions of the same formula (e.g. postgresql@14, @15, @16)
        try:
            r = subprocess.run(
                ["brew", "list", "--formula"],
                capture_output=True, text=True, timeout=10,
            )
            if r.returncode == 0:
                from collections import defaultdict
                versioned = defaultdict(list)  # base_name -> [full_name, ...]
                for formula in r.stdout.splitlines():
                    formula = formula.strip()
                    if "@" in formula:
                        base = formula.split("@")[0]
                        versioned[base].append(formula)
                for base, versions in versioned.items():
                    if len(versions) < 2:
                        continue
                    # Get sizes
                    ver_info = []
                    for v in sorted(versions):
                        cellar_path = os.path.join(brew_prefix, "Cellar", v)
                        size = dir_size_if_exists(cellar_path)
                        ver_info.append((v, size))
                    total = sum(s for _, s in ver_info)
                    if total < 50_000_000:
                        continue
                    ver_list = ", ".join(v for v, _ in ver_info)
                    # Suggest keeping the latest
                    oldest = ver_info[:-1]
                    oldest_size = sum(s for _, s in oldest)
                    oldest_names = " ".join(v for v, _ in oldest)
                    if oldest_size > 0:
                        add(f"Multiple {base} versions",
                            f"Installed: {ver_list} — consider keeping only the latest",
                            oldest_size,
                            f"brew uninstall {oldest_names}  (check: brew uses --installed {oldest_names})",
                            REVIEW)
        except Exception:
            pass

    except (FileNotFoundError, Exception):
        pass

    return targets


