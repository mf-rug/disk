#!/usr/bin/env python3
"""Pretty disk usage analysis tool for macOS."""

import argparse
import os
import stat as stat_module
import subprocess
import sys


# ── ANSI colors ──────────────────────────────────────────────────────────────

USE_COLOR = sys.stdout.isatty() and os.environ.get("TERM", "") != "dumb"


def c(code, text):
    return f"\033[{code}m{text}\033[0m" if USE_COLOR else text


def bold(t):
    return c("1", t)


def dim(t):
    return c("2", t)


def green(t):
    return c("32", t)


def yellow(t):
    return c("33", t)


def red(t):
    return c("31", t)


def cyan(t):
    return c("36", t)


def color_for_pct(pct):
    if pct < 60:
        return green
    elif pct < 80:
        return yellow
    return red


# ── Size formatting ──────────────────────────────────────────────────────────


def fmt_bytes(n):
    """Format bytes into human-readable string."""
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if abs(n) < 1000:
            if unit in ("B", "KB"):
                return f"{n:.0f} {unit}"
            return f"{n:.1f} {unit}"
        n /= 1000
    return f"{n:.1f} PB"


# ── Progress bar ─────────────────────────────────────────────────────────────

BAR_WIDTH = 30


def bar(pct, width=BAR_WIDTH):
    filled = int(round(pct / 100 * width))
    empty = width - filled
    colorize = color_for_pct(pct)
    return colorize("█" * filled) + dim("░" * empty)


# ── Disk discovery ───────────────────────────────────────────────────────────

# Mount points to always skip
SKIP_MOUNTS = {
    "/dev",
    "/System/Volumes/VM",
    "/System/Volumes/Preboot",
    "/System/Volumes/Update",
    "/System/Volumes/xarts",
    "/System/Volumes/iSCPreboot",
    "/System/Volumes/Hardware",
    "/System/Volumes/Data/home",
    "/System/Volumes/Update/mnt1",
    "/System/Volumes/Update/SFR/mnt1",
}

# Filesystem types to skip
SKIP_FS = {"devfs", "map"}


def get_diskutil_info(device):
    """Get volume info from diskutil."""
    try:
        r = subprocess.run(
            ["/usr/sbin/diskutil", "info", device],
            capture_output=True, text=True, timeout=5,
        )
        info = {}
        for line in r.stdout.splitlines():
            if ":" in line:
                key, _, val = line.partition(":")
                info[key.strip()] = val.strip()
        return info
    except Exception:
        return {}


def parse_df_line(line):
    """Parse a df -b line into (filesystem, blocks_total, blocks_used, blocks_avail, mount).

    df -b columns: Filesystem 512-blocks Used Available Capacity Mounted-on
    The mount point may contain spaces, so we split carefully.
    """
    parts = line.split()
    if len(parts) < 6:
        return None
    fs = parts[0]
    try:
        total = int(parts[1])
        used = int(parts[2])
        avail = int(parts[3])
    except ValueError:
        return None
    # parts[4] is Capacity%, mount is everything from parts[5] onward
    mount = " ".join(parts[5:])
    return fs, total, used, avail, mount


def get_disks():
    """Parse df and return list of meaningful disks."""
    r = subprocess.run(["/bin/df", "-b"], capture_output=True, text=True)
    disks = []
    boot_device = None

    lines = r.stdout.splitlines()[1:]

    # Parse all lines first
    parsed = [parse_df_line(l) for l in lines]
    parsed = [p for p in parsed if p is not None]

    # Find the boot device (root mount)
    for fs, _, _, _, mount in parsed:
        if mount == "/":
            boot_device = fs.replace("/dev/", "").split("s")[0]
            break

    seen_containers = set()

    for fs, blocks_total, blocks_used, blocks_avail, mount in parsed:
        # Skip virtual/system mounts
        if mount in SKIP_MOUNTS:
            continue
        if any(fs.startswith(s) for s in SKIP_FS):
            continue

        # For APFS, only keep the Data volume (or root if no Data seen)
        device = fs.replace("/dev/", "")
        container = device.split("s")[0] if device.startswith("disk") else None

        if container and container in seen_containers:
            continue

        # Detect if this is the main APFS data volume or root
        is_data = mount == "/System/Volumes/Data"
        is_root = mount == "/"

        if is_data and container:
            seen_containers.add(container)
        elif is_root and container:
            # Skip root if we'll see Data volume for same container
            has_data = any(
                m == "/System/Volumes/Data"
                for f, _, _, _, m in parsed
                if f.replace("/dev/", "").split("s")[0] == container
            )
            if has_data:
                continue
            seen_containers.add(container)

        # Convert 512-byte blocks to bytes
        total = blocks_total * 512
        used = blocks_used * 512
        avail = blocks_avail * 512

        # Get disk info
        info = get_diskutil_info(fs) if fs.startswith("/dev/") else {}
        vol_name = info.get("Volume Name", "")
        media_type = info.get("Media Type", "")
        protocol = info.get("Protocol", "")
        virtual = info.get("Virtual", "No")

        # Determine disk type label
        is_boot = container and container == boot_device
        if fs.startswith("http") or fs.startswith("smb") or fs.startswith("nfs") or fs.startswith("afp"):
            disk_type = "Network"
            vol_name = vol_name or mount.split("/")[-1]
        elif virtual == "Yes" or "disk image" in media_type.lower():
            disk_type = "Disk Image"
        elif is_boot:
            disk_type = f"Internal SSD ({protocol})" if protocol else "Internal SSD"
            vol_name = "Macintosh HD"
        elif protocol in ("USB", "Thunderbolt"):
            disk_type = f"External ({protocol})"
        elif protocol:
            disk_type = f"Internal ({protocol})"
        else:
            disk_type = "Volume"

        if not vol_name:
            vol_name = mount.split("/")[-1] or mount

        disks.append({
            "name": vol_name,
            "type": disk_type,
            "mount": mount,
            "device": fs,
            "total": total,
            "used": used,
            "avail": avail,
            "is_boot": is_boot,
        })

    # Sort: boot drive first, then by name
    disks.sort(key=lambda d: (not d["is_boot"], d["name"].lower()))
    return disks


# ── Default display ──────────────────────────────────────────────────────────


def print_disks(disks):
    print()
    for i, d in enumerate(disks):
        star = "★ " if d["is_boot"] else ""
        print(f"  {bold(star + d['name'])} {dim('—')} {dim(d['type'])}")

        if d["total"] > 0:
            pct = d["used"] / d["total"] * 100 if d["total"] else 0
            colorize = color_for_pct(pct)
            print(f"  {bar(pct)}  {fmt_bytes(d['used'])} / {fmt_bytes(d['total'])} used ({colorize(f'{pct:.0f}%')})")
            print(f"  {fmt_bytes(d['avail'])} available")
        else:
            print(f"  {dim('(usage unavailable)')}")

        if i < len(disks) - 1:
            print()
    print()


# ── Detailed breakdown ───────────────────────────────────────────────────────


def du_size(path):
    """Get total size of a path in bytes using du."""
    try:
        r = subprocess.run(
            ["/usr/bin/du", "-sk", path],
            capture_output=True, text=True, timeout=30,
        )
        # du may return rc=1 due to permission errors but still output a total
        if r.stdout.strip():
            return int(r.stdout.split()[0]) * 1024
    except Exception:
        pass
    return 0


def file_count(path):
    """Count files in a directory (fast — just reads dir entries)."""
    try:
        r = subprocess.run(
            ["/usr/bin/find", path, "-type", "f"],
            stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
            text=True, timeout=30,
        )
        if r.returncode in (0, 1):  # 1 = some permission errors, still has output
            return r.stdout.count("\n")
    except Exception:
        pass
    return 0


def fmt_count(n):
    """Format file count with thousands separators."""
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M files"
    if n >= 1_000:
        return f"{n / 1_000:.1f}k files"
    return f"{n} files"


def scan_categories(home, total_used):
    """Scan home directory and /Applications for storage breakdown.

    Returns (categories, system_size) where categories is a list of
    (name, size, count) tuples.
    """
    categories = []

    # Scan ~/  subdirectories
    try:
        entries = sorted(os.listdir(home))
    except OSError:
        entries = []

    print(f"  {dim('Scanning storage...')}", end="", flush=True)

    for entry in entries:
        path = os.path.join(home, entry)
        if not os.path.isdir(path) or os.path.islink(path):
            continue
        size = du_size(path)
        if size > 0:
            count = file_count(path)
            categories.append((entry, size, count))
        print(dim("."), end="", flush=True)

    # /Applications
    apps_size = du_size("/Applications")
    if apps_size > 0:
        apps_count = file_count("/Applications")
        categories.append(("Applications", apps_size, apps_count))
    print(dim("."), end="", flush=True)

    # Sort by size descending
    categories.sort(key=lambda x: -x[1])

    # Calculate system/other
    accounted = sum(s for _, s, _ in categories)
    system_size = max(0, total_used - accounted)

    # Clear scanning line
    print(f"\r{' ' * 60}\r", end="", flush=True)

    return categories, system_size


def print_details(disks):
    # Find boot disk
    boot = next((d for d in disks if d["is_boot"]), None)
    if not boot:
        print(f"  {red('Could not identify boot volume.')}")
        return

    home = os.path.expanduser("~")
    categories, system_size = scan_categories(home, boot["used"])

    # Group: hidden dirs → "Caches & App Data", small entries → "Other"
    visible = []
    hidden_total = 0
    hidden_count = 0
    other_total = 0
    other_count = 0
    for name, size, count in categories:
        if name.startswith("."):
            hidden_total += size
            hidden_count += count
        elif size >= 500_000_000:  # 500 MB
            visible.append((name, size, count))
        else:
            other_total += size
            other_count += count

    # Build final list: (name, size, count)
    final = list(visible)
    if hidden_total > 0:
        final.append(("Caches & App Data", hidden_total, hidden_count))
    if system_size > 0:
        final.append(("System & Other", system_size, 0))
    if other_total > 0:
        final.append(("Other", other_total, other_count))

    # Sort by size descending
    final.sort(key=lambda x: -x[1])

    # Find max name length for alignment
    max_name = max(len(n) for n, _, _ in final) if final else 10
    max_name = max(max_name, 18)

    # Add free space so everything sums to 100%
    final.append(("Free Space", boot["avail"], 0))

    # Print
    print(f"  {bold('Storage Breakdown')}")
    line_width = max_name + 48
    print(f"  {dim('─' * line_width)}")

    total = boot["total"]
    detail_bar_width = 16
    for name, size, count in final:
        pct = size / total * 100 if total else 0
        filled = int(round(pct / 100 * detail_bar_width))
        empty = detail_bar_width - filled
        count_str = dim(fmt_count(count)) if count > 0 else ""
        is_free = name == "Free Space"
        if is_free:
            print(f"  {dim('─' * line_width)}")
            bar_str = dim("░" * detail_bar_width)
            size_str = f"{fmt_bytes(size):>9}"
            pct_str = f"{pct:>5.1f}%"
            print(f"  {dim(f'{name:<{max_name}}')}  {dim(size_str)}  {bar_str}  {dim(pct_str)}")
        else:
            colorize = color_for_pct(pct * (100 / max(1, boot["used"] / boot["total"] * 100)))
            bar_str = colorize("█" * filled) + dim("░" * empty)
            print(f"  {name:<{max_name}}  {fmt_bytes(size):>9}  {bar_str}  {pct:>5.1f}%  {count_str}")

    print()


# ── Cleanup suggestions ─────────────────────────────────────────────────────

import glob as globmod


def glob_size(pattern):
    """Total size of files matching a glob pattern."""
    total = 0
    for path in globmod.glob(pattern):
        try:
            if os.path.isfile(path) and not os.path.islink(path):
                total += os.path.getsize(path)
        except OSError:
            pass
    return total


def dir_size_if_exists(path):
    """Size of a directory, 0 if missing."""
    if os.path.isdir(path):
        return du_size(path)
    return 0


# Risk levels for cleanup targets
SAFE = "safe"        # pure caches, auto-regenerated — delete freely
REVIEW = "review"    # probably fine, but worth a quick look first
CAUTION = "caution"  # may contain files you actually want

RISK_LABELS = {
    SAFE:    ("Safe",    green,  "auto-regenerated cache, safe to delete"),
    REVIEW:  ("Review",  yellow, "probably fine, but check first"),
    CAUTION: ("Caution", red,    "may contain files you want — inspect before deleting"),
}


