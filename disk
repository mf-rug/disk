import time as _time


def age_color(mtime):
    """Color based on file age: dim=recent, yellow=>6mo, red=>1yr."""
    age_days = (_time.time() - mtime) / 86400
    if age_days > 365:
        return red
    elif age_days > 180:
        return yellow
    return dim


def age_label(mtime):
    """Human-readable age string."""
    age_days = int((_time.time() - mtime) / 86400)
    if age_days > 365:
        years = age_days / 365
        return f"{years:.1f}y ago"
    elif age_days > 30:
        months = age_days / 30
        return f"{months:.0f}mo ago"
    elif age_days > 0:
        return f"{age_days}d ago"
    return "today"


def find_big_files(search_dir, count=20):
    """Find the largest files under search_dir using du + sort pipeline."""
    import heapq

    home = os.path.expanduser("~")
    skip_prefixes = (
        "/System/Volumes/",
        os.path.join(home, ".Trash") + "/",
        "/Library/Apple/System/",
        # Cloud storage — not actually on disk
        os.path.join(home, "Google Drive") + "/",
        os.path.join(home, "OneDrive") + "/",
        os.path.join(home, "Dropbox") + "/",
        os.path.join(home, "Library", "CloudStorage") + "/",
        os.path.join(home, "Library", "Mobile Documents") + "/",  # iCloud
    )

    # Walk the filesystem in Python — much faster than find -exec stat
    # We only keep the top N using a min-heap
    heap = []  # min-heap of (size, mtime, path)

    try:
        for dirpath, dirnames, filenames in os.walk(search_dir):
            # Skip system dirs
            if any(dirpath.startswith(p) for p in skip_prefixes):
                dirnames.clear()
                continue
            for fname in filenames:
                fpath = os.path.join(dirpath, fname)
                try:
                    st = os.lstat(fpath)
                    if not stat_module.S_ISREG(st.st_mode):
                        continue
                    size = st.st_size
                    if len(heap) < count:
                        heapq.heappush(heap, (size, st.st_mtime, fpath))
                    elif size > heap[0][0]:
                        heapq.heapreplace(heap, (size, st.st_mtime, fpath))
                except OSError:
                    continue
    except OSError:
        pass

    # Return sorted biggest first
    heap.sort(key=lambda x: -x[0])
    return heap


def print_big_files(search_dir, count=20):
    """Print the biggest files."""
    print()
    print(f"  {bold(f'Biggest files in {search_dir}')}")
    print(f"  {dim('Scanning (this may take a moment)...')}", end="", flush=True)

    files = find_big_files(search_dir, count)
    print(f"\r{' ' * 60}\r", end="", flush=True)

    if not files:
        print(f"  {dim('No files found.')}")
        print()
        return

    home = os.path.expanduser("~")

    print(f"  {dim('─' * 70)}")

    for size, mtime, path in files:
        display = path.replace(home, "~")
        ac = age_color(mtime)
        al = age_label(mtime)

        print(f"  {bold(fmt_bytes(size)):>9}  {ac(f'{al:>8}')}  {display}")

    print(f"  {dim('─' * 70)}")
    print()


def print_system_details(disks):
    """Drill into the 'System & Other' bucket."""
    boot = next((d for d in disks if d["is_boot"]), None)
    if not boot:
        print(f"  {red('Could not identify boot volume.')}")
        return

    home = os.path.expanduser("~")

    # First compute what ~/  and /Applications account for (same as print_details)
    categories, system_size = scan_categories(home, boot["used"])

    if system_size <= 0:
        print(f"  {dim('No unaccounted system storage.')}")
        return

    print(f"  {bold('System & Other Breakdown')}")
    print(f"  {dim(f'{fmt_bytes(system_size)} unaccounted — scanning system directories...')}")
    print(f"  {dim('Run with sudo for full accuracy: sudo disk system')}")
    print()

    # Scan the major system directories
    # NOTE: /System is excluded — it's a firmlinked APFS volume that
    # shares blocks with the Data volume, so du massively double-counts it.
    # Its actual unique size is ~15 GB but du reports ~800+ GB.
    system_dirs = [
        ("/opt/homebrew", "Homebrew (Apple Silicon)"),
        ("/usr/local", "Homebrew (Intel) & local tools"),
        ("/Library", "System-wide app support & frameworks"),
        ("/private/var", "System data, databases, logs, VM"),
    ]

    # Other users
    try:
        current_user = os.path.basename(home)
        for entry in os.listdir("/Users"):
            if entry in (current_user, "Shared", ".localized"):
                continue
            user_path = os.path.join("/Users", entry)
            if os.path.isdir(user_path) and not os.path.islink(user_path):
                system_dirs.append((user_path, f"User: {entry}"))
    except OSError:
        pass

    entries = []
    print(f"  {dim('Scanning...')}", end="", flush=True)

    for path, label in system_dirs:
        if not os.path.exists(path):
            continue
        size = du_size(path)
        if size > 0:
            entries.append((label, size))
        print(dim("."), end="", flush=True)

    print(f"\r{' ' * 60}\r", end="", flush=True)

    # Calculate remainder (snapshots, purgeable, stuff du can't see)
    scanned = sum(s for _, s in entries)
    remainder = max(0, system_size - scanned)

    # Group small entries
    threshold = max(system_size * 0.02, 50_000_000)  # 2% or 50 MB
    big = []
    other = 0
    for name, size in entries:
        if size >= threshold:
            big.append((name, size))
        else:
            other += size

    if remainder > 0:
        big.append(("Unscanned (needs sudo) + snapshots", remainder))
    if other > 0:
        big.append(("Other system dirs", other))

    big.sort(key=lambda x: -x[1])

    max_name = max(len(n) for n, _ in big) if big else 10
    max_name = max(max_name, 26)
    line_width = max_name + 35

    print(f"  {dim('─' * line_width)}")

    detail_bar_width = 16
    for name, size in big:
        pct = size / system_size * 100 if system_size else 0
        filled = int(round(pct / 100 * detail_bar_width))
        empty = detail_bar_width - filled
        is_remainder = name in ("Unscanned (needs sudo) + snapshots", "Other system dirs")
        if is_remainder:
            bar_str = dim("░" * detail_bar_width)
            size_str = f"{fmt_bytes(size):>9}"
            pct_str = f"{pct:>5.1f}%"
            print(f"  {dim(f'{name:<{max_name}}')}  {dim(size_str)}  {bar_str}  {dim(pct_str)}")
        else:
            colorize = color_for_pct(pct)
            bar_str = colorize("█" * filled) + dim("░" * empty)
            print(f"  {name:<{max_name}}  {fmt_bytes(size):>9}  {bar_str}  {pct:>5.1f}%")

    print(f"  {dim('─' * line_width)}")
    print()


def main():
    parser = argparse.ArgumentParser(
        description="Pretty disk usage analysis for macOS",
    )
    parser.add_argument(
        "directory", nargs="?", default=None,
        help="Show subdirectory breakdown for a directory, or 'system' to drill into System & Other",
    )
    parser.add_argument(
        "--details", "-d",
        action="store_true",
        help="Show storage breakdown by category (like System Settings > Storage)",
    )
    parser.add_argument(
        "--clean", "-c",
        action="store_true",
        help="Scan for cleanup opportunities (caches, temp files, old downloads)",
    )
    parser.add_argument(
        "--big", "-b",
        action="store_true",
        help="Find the 20 biggest files (default: /, or in given directory)",
    )
    args = parser.parse_args()

    if args.big:
        search_dir = os.path.abspath(os.path.expanduser(args.directory)) if args.directory else "/"
        print_big_files(search_dir)
        return

    if args.directory:
        if args.directory.lower() == "system":
            disks = get_disks()
            print_disks(disks)
            print_system_details(disks)
        else:
            print_dir_breakdown(args.directory)
        return

    disks = get_disks()
    print_disks(disks)

    if args.details:
        print_details(disks)
        # Hint about system drill-down
        print(f"  {dim('Tip: run `disk system` to drill into System & Other')}")
        print()

    if args.clean:
        print_clean()


if __name__ == "__main__":
    main()
