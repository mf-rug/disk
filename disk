        "Files in the Trash — you already deleted these once",
        dir_size_if_exists(os.path.join(home, ".Trash")),
        "Empty via Finder or: rm -rf ~/.Trash/*",
        REVIEW)

    # DMGs in Downloads
    add("DMGs in Downloads",
        "Disk images — usually safe to delete after installing apps",
        glob_size(os.path.join(home, "Downloads", "*.dmg")),
        "rm ~/Downloads/*.dmg",
        REVIEW)

    # ZIPs in Downloads
    add("ZIPs in Downloads",
        "Could be anything — review before bulk-deleting",
        glob_size(os.path.join(home, "Downloads", "*.zip")),
        "ls -lhS ~/Downloads/*.zip  (review, then delete selectively)",
        CAUTION)

    # PKGs in Downloads
    add("Installers in Downloads",
        "macOS installer packages — safe to delete after installation",
        glob_size(os.path.join(home, "Downloads", "*.pkg")),
        "rm ~/Downloads/*.pkg",
        REVIEW)

    # Xcode DerivedData
    add("Xcode DerivedData",
        "Build artifacts — Xcode will regenerate as needed",
        dir_size_if_exists(os.path.join(home, "Library", "Developer",
                                        "Xcode", "DerivedData")),
        "rm -rf ~/Library/Developer/Xcode/DerivedData")

    # Xcode iOS device support
    add("Xcode Device Support",
        "Old iOS version support files",
        dir_size_if_exists(os.path.join(home, "Library", "Developer",
                                        "Xcode", "iOS DeviceSupport")),
        "rm -rf ~/Library/Developer/Xcode/iOS\\ DeviceSupport/*",
        REVIEW)

    # Homebrew cache
    add("Homebrew cache",
        "Downloaded bottles and source archives",
        dir_size_if_exists(os.path.join(home, "Library", "Caches",
                                        "Homebrew")),
        "brew cleanup --prune=all")

    # pip cache
    pip_cache = dir_size_if_exists(os.path.join(home, "Library", "Caches", "pip"))
    if pip_cache == 0:
        pip_cache = dir_size_if_exists(os.path.join(home, ".cache", "pip"))
    add("pip cache",
        "Cached Python package downloads",
        pip_cache,
        "pip cache purge")

    # Conda packages
    add("Conda package cache",
        "Cached conda packages — can be re-downloaded",
        dir_size_if_exists(os.path.join(home, "anaconda3", "pkgs")),
        "rm -rf ~/anaconda3/pkgs")

    # npm cache
    add("npm cache",
        "Cached npm packages",
        dir_size_if_exists(os.path.join(home, ".npm", "_cacache")),
        "npm cache clean --force")

    # Gradle caches
    add("Gradle cache",
        "Build caches and downloaded dependencies",
        dir_size_if_exists(os.path.join(home, ".gradle", "caches")),
        "rm -rf ~/.gradle/caches")

    # Cargo registry
    cargo_reg = dir_size_if_exists(os.path.join(home, ".cargo", "registry"))
    cargo_git = dir_size_if_exists(os.path.join(home, ".cargo", "git"))
    add("Cargo cache",
        "Cached Rust crate sources and git repos",
        cargo_reg + cargo_git,
        "rm -rf ~/.cargo/registry ~/.cargo/git")

    # ~/Library/Logs
    add("Application logs",
        "Log files from various apps — useful if debugging issues",
        dir_size_if_exists(os.path.join(home, "Library", "Logs")),
        "rm -rf ~/Library/Logs/*",
        REVIEW)

    # Crash reports & diagnostics
    diag_size = (
        dir_size_if_exists(os.path.join(home, "Library", "Logs", "DiagnosticReports"))
        + dir_size_if_exists("/Library/Logs/DiagnosticReports")
        + dir_size_if_exists(os.path.join(home, "Library", "Application Support", "CrashReporter"))
    )
    add("Crash reports",
        "App crash logs and diagnostic data — useful if diagnosing recurring crashes",
        diag_size,
        "rm -rf ~/Library/Logs/DiagnosticReports/* ~/Library/Application\\ Support/CrashReporter/*",
        REVIEW)

    # ── ~/Library/Caches — scan top offenders individually ──
    lib_caches = os.path.join(home, "Library", "Caches")
    # Dirs we already report separately (avoid double-counting)
    already_reported_caches = {
        "Homebrew", "pip",
        "Google",  # Chrome cache
        "Firefox",
        "BraveSoftware",
        "Microsoft Edge",
        "com.apple.Safari",
        "us.zoom.xos",
    }
    if os.path.isdir(lib_caches):
        cache_entries = []
        try:
            for entry in os.listdir(lib_caches):
                if entry in already_reported_caches:
                    continue
                path = os.path.join(lib_caches, entry)
                if os.path.isdir(path) and not os.path.islink(path):
                    size = du_size(path)
                    if size >= 100_000_000:  # 100 MB+
                        cache_entries.append((entry, size))
        except OSError:
            pass
        cache_entries.sort(key=lambda x: -x[1])
        for entry, size in cache_entries:
            add(f"Cache: {entry}",
