def print_dir_breakdown(target_dir):
    """Show subdirectory sizes for a given directory."""
    target_dir = os.path.abspath(os.path.expanduser(target_dir))
    if not os.path.isdir(target_dir):
        print(f"  {red(f'Not a directory: {target_dir}')}")
        return

    # Get total size of the target directory
    total_size = du_size(target_dir)
    total_count = file_count(target_dir)

    print()
    print(f"  {bold(target_dir)}")
    print(f"  {fmt_bytes(total_size)} total, {fmt_count(total_count)}")
    print()

    # Scan subdirectories
    entries = []
    files_size = 0
    files_count = 0

    print(f"  {dim('Scanning...')}", end="", flush=True)

    try:
        for entry in sorted(os.listdir(target_dir)):
            path = os.path.join(target_dir, entry)
            if os.path.islink(path):
                continue
            if os.path.isdir(path):
                size = du_size(path)
                count = file_count(path)
                if size > 0:
                    entries.append((entry, size, count))
                print(dim("."), end="", flush=True)
            elif os.path.isfile(path):
                try:
                    files_size += os.path.getsize(path)
                    files_count += 1
                except OSError:
                    pass
    except OSError as e:
        print(f"\r  {red(f'Cannot read directory: {e}')}")
        return

    print(f"\r{' ' * 60}\r", end="", flush=True)

    # Add loose files as a category
    if files_size > 0:
        entries.append(("[files in this dir]", files_size, files_count))

    entries.sort(key=lambda x: -x[1])

    if not entries:
        print(f"  {dim('(empty directory)')}")
        return

    # Group small entries (<1% of total or < 10 MB) into "Other"
    threshold = max(total_size * 0.01, 10_000_000)  # 1% or 10 MB
    big = []
    other_size = 0
    other_count = 0
    for name, size, count in entries:
        if size >= threshold:
            big.append((name, size, count))
        else:
            other_size += size
            other_count += count

    if other_size > 0:
        big.append(("Other", other_size, other_count))

    max_name = max(len(n) for n, _, _ in big)
    max_name = max(max_name, 10)
    line_width = max_name + 48

    print(f"  {dim('─' * line_width)}")

    detail_bar_width = 16
    for name, size, count in big:
        pct = size / total_size * 100 if total_size else 0
        filled = int(round(pct / 100 * detail_bar_width))
        empty = detail_bar_width - filled
        is_other = name == "Other"
        if is_other:
            bar_str = dim("░" * detail_bar_width)
            count_str = dim(fmt_count(count)) if count > 0 else ""
            size_str = f"{fmt_bytes(size):>9}"
            pct_str = f"{pct:>5.1f}%"
            print(f"  {dim(f'{name:<{max_name}}')}  {dim(size_str)}  {bar_str}  {dim(pct_str)}  {count_str}")
        else:
            colorize = color_for_pct(pct)
            bar_str = colorize("█" * filled) + dim("░" * empty)
            count_str = dim(fmt_count(count)) if count > 0 else ""
            print(f"  {name:<{max_name}}  {fmt_bytes(size):>9}  {bar_str}  {pct:>5.1f}%  {count_str}")

    print(f"  {dim('─' * line_width)}")
    print()


